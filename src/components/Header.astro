---
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/code', label: '技术' },
  { href: '/video', label: '视频' },
  { href: '/quote', label: '一言' },
  { href: '/about', label: '关于' },
];
---

<header class="sticky top-0 z-50 bg-bg border-b border-border h-header">
  <div class="max-w-content mx-auto px-6 h-full flex items-center justify-between gap-6">
    <a href="/" class="flex flex-col no-underline">
      <span class="text-xl font-bold text-special">Bubble</span>
      <span class="text-xs text-text-secondary hidden sm:block">小六家的藏宝图</span>
    </a>

    <nav class="hidden sm:flex gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-2 py-1 text-text text-sm rounded transition-colors duration-200 hover:bg-bg-secondary hover:text-text"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex gap-2">
      <button
        id="search-btn"
        class="flex items-center justify-center w-10 h-10 border-none bg-transparent text-text cursor-pointer rounded-lg transition-colors duration-200 hover:bg-bg-secondary"
        aria-label="搜索"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <button
        id="theme-toggle"
        class="flex items-center justify-center w-10 h-10 border-none bg-transparent text-text cursor-pointer rounded-lg transition-colors duration-200 hover:bg-bg-secondary"
        aria-label="切换主题"
      >
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Theme toggle icons - 无法用 Tailwind 直接表达的样式 */
  [data-theme="light"] .moon-icon,
  [data-theme="dark"] .sun-icon {
    display: none;
  }
</style>

<script>
  const themeToggle = document.getElementById('theme-toggle');

  themeToggle?.addEventListener('click', () => {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  });
</script>
