---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  author?: string;
  tags?: string[];
  image?: string;
}

const { title, description, date, author = 'hexsix', tags = [], image } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article class="max-w-full">
    <header class="mb-6 pb-4 border-b border-border">
      <h1 class="text-xl sm:text-2xl font-semibold leading-snug mb-2 text-text">{title}</h1>
      <div class="flex flex-wrap items-center gap-1.5 text-xs text-text-secondary">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-border/60">·</span>
        <span>{author}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {tags.map(tag => (
            <a
              href={`/tags/${tag.toLowerCase()}`}
              class="inline-flex items-center px-2 py-0.5 text-[11px] text-special/80 border border-special/20 rounded hover:bg-special/5 hover:border-special/40 transition-all duration-200"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="article-content mb-12">
      <slot />
    </div>

    <footer class="mt-12 pt-8 border-t border-border">
      <Giscus />
    </footer>
  </article>
</BaseLayout>
