---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all posts from all collections
const allCode = await getCollection('code', ({ data }) => !data.draft);
const allArticle = await getCollection('article', ({ data }) => !data.draft);
const allVideo = await getCollection('video');
const allQuote = await getCollection('quote');

// Combine and sort by date
const allPosts = [...allCode, ...allArticle, ...allVideo, ...allQuote]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 10);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

const getPostUrl = (post: typeof allPosts[0]) => {
  return `/${post.collection}/${post.id}`;
};

const getPostType = (collection: string) => {
  const types: Record<string, string> = {
    code: '技术',
    article: '文章',
    video: '视频',
    quote: '一言',
  };
  return types[collection] || collection;
};
---

<BaseLayout title="首页">
  <section class="text-center py-12 mb-8">
    <h1 class="text-5xl sm:text-6xl font-bold text-special mb-2">Bubble</h1>
    <p class="text-xl text-text-secondary m-0">小六家的藏宝图</p>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-semibold mb-6 pb-2 border-b-2 border-base">最新文章</h2>
    <ul class="list-none p-0 m-0">
      {allPosts.map(post => (
        <li class="mb-2">
          <a
            href={getPostUrl(post)}
            class="flex items-center gap-4 p-4 rounded-lg no-underline transition-colors duration-200 hover:bg-bg-secondary sm:flex-nowrap flex-wrap"
          >
            <span class="shrink-0 px-2 py-1 text-xs font-medium text-special bg-base rounded">
              {getPostType(post.collection)}
            </span>
            <h3 class="flex-1 text-base font-medium text-text m-0">{post.data.title}</h3>
            <time
              class="shrink-0 text-sm text-text-secondary sm:w-auto w-full sm:ml-0 ml-[calc(1rem+3rem)]"
              datetime={post.data.date.toISOString()}
            >
              {formatDate(post.data.date)}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="flex flex-wrap gap-4 justify-center">
    <a
      href="/code"
      class="px-6 py-2 text-sm text-special border border-special rounded-full transition-all duration-200 hover:bg-special hover:text-white"
    >
      查看所有技术文章 &rarr;
    </a>
    <a
      href="/video"
      class="px-6 py-2 text-sm text-special border border-special rounded-full transition-all duration-200 hover:bg-special hover:text-white"
    >
      查看所有视频 &rarr;
    </a>
    <a
      href="/quote"
      class="px-6 py-2 text-sm text-special border border-special rounded-full transition-all duration-200 hover:bg-special hover:text-white"
    >
      查看所有一言 &rarr;
    </a>
  </section>
</BaseLayout>
