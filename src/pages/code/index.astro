---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('code', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<BaseLayout title="技术文章" description="技术教程、开发笔记和代码分享">
  <header class="mb-12">
    <h1 class="text-3xl font-bold mb-2">技术文章</h1>
    <p class="text-text-secondary m-0">技术教程、开发笔记和代码分享</p>
  </header>

  <ul class="list-none p-0 m-0">
    {sortedPosts.map(post => (
      <li class="border-b border-border last:border-b-0">
        <a
          href={`/code/${post.id}`}
          class="flex items-center justify-between gap-4 py-6 no-underline transition-opacity duration-200 hover:opacity-80"
        >
          <div class="flex-1">
            <h2 class="text-lg font-semibold text-text m-0 mb-1">{post.data.title}</h2>
            <div class="flex flex-wrap items-center gap-2 text-sm text-text-secondary">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="flex gap-1">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="text-special">#{tag}</span>
                  ))}
                </span>
              )}
            </div>
          </div>
          <span class="text-text-secondary text-xl">&rarr;</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
