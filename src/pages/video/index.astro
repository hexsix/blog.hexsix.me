---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('video');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

const getPlatform = (post: typeof sortedPosts[0]) => {
  if (post.data.youtube) return 'YouTube';
  if (post.data.bilibili) return 'Bilibili';
  return '';
};
---

<BaseLayout title="视频" description="收藏的视频分享">
  <header class="mb-12">
    <h1 class="text-3xl font-bold mb-2">视频</h1>
    <p class="text-text-secondary m-0">收藏的视频分享</p>
  </header>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6">
    {sortedPosts.map(post => (
      <a
        href={`/video/${post.id}`}
        class="block no-underline rounded-xl overflow-hidden bg-bg-secondary transition-all duration-200 hover:-translate-y-1 hover:shadow-lg"
      >
        <div class="relative aspect-video bg-gradient-to-br from-base to-highlight flex items-center justify-center">
          <span class="px-2 py-1 text-xs font-semibold text-white bg-black/50 rounded">
            {getPlatform(post)}
          </span>
        </div>
        <div class="p-4">
          <h2 class="text-base font-semibold text-text m-0 mb-1 leading-snug">{post.data.title}</h2>
          <time class="text-sm text-text-secondary" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
